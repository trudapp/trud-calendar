{
  "name": "trud-calendar",
  "version": "1.0.0",
  "description": "A beautiful, fully-featured React calendar component. Google Calendar-level UX, MIT license, shadcn-compatible.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trudapp/trud-calendar",
    "directory": "packages/react"
  },
  "homepage": "https://trud-calendar-docs.vercel.app/",
  "keywords": ["react", "calendar", "drag-and-drop", "typescript", "shadcn", "tailwind", "i18n", "recurrence", "component"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.0.0",
    "trud-calendar-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": ["*.css"]
}
